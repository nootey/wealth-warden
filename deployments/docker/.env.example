# Compose / Traefik
# HOST is the public domain for Traefik routing rules (not the server bind address)
HOST=localhost
TRAEFIK_EMAIL=support@wealth.warden

# Server
RELEASE=false
FINANCE_API_BASE_URL=https://query1.finance.yahoo.com
HTTP_SERVER_PORT=2000
HTTP_SERVER_REQUEST_TIMEOUT=60

# Web Client
WEB_CLIENT_DOMAIN=localhost
WEB_CLIENT_PORT=5000

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DB=wealth_warden

# Redis (required in release mode - defaults are rejected)
REDIS_PASSWORD=

# Sessions (hours)
SESSION_TTL_HOURS=24
SESSION_REMEMBER_ME_TTL_HOURS=720
SESSION_MAX_LIFETIME_HOURS=2160

# CORS (comma-separated lists)
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://app:5000
CORS_WILDCARD_SUFFIXES=
CORS_ALLOWED_SCHEMES=http

# Mailer
MAILER_HOST=
MAILER_PORT=587
MAILER_USERNAME=
MAILER_PASSWORD=

# Seed
SEED_SUPER_ADMIN_EMAIL=admin@wealth.warden
SEED_SUPER_ADMIN_PASSWORD=password
SEED_MEMBER_USER_EMAIL=
SEED_MEMBER_USER_PASSWORD=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=tempo:4317
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
