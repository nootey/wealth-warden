      "panel-10": {
        "kind": "Panel",
        "spec": {
          "id": 10,
          "title": "Queue job error rate",
          "description": "hare of queue job executions that failed, over a 5m window (failures ÷ total runs). Reads 0% when there's no traffic or no failures. Counters reset on app restart, so this reflects the current process only.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "prometheus"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "(sum(rate(queue_job_runs_total{status=\"failure\"}[5m])) or vector(0))/clamp_min(sum(rate(queue_job_runs_total[5m])), 1)",
                        "legendFormat": "__auto",
                        "range": true
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "13.0.2",
